# BRIDGE environment. Copy to .env.local and fill in. Never commit real values.

# Supabase (from the bridge project, not any other)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Model providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# News
BRAVE_API_KEY=

# Web push (generate a fresh pair, do not reuse)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Seats: comma-separated emails, seat order 1..4 (Kabir, Derek, Amy, Krish).
# Empty positions keep that seat unloginable until filled.
SEAT_ALLOWLIST=,,,krish@themindmaker.ai

# App
APP_TIMEZONE=America/New_York

# Demo mode: auth bypass and seed-file data source. Ignored on production deploys.
DEMO_MODE=false

# Cron secret for scheduled endpoints
CRON_SECRET=
